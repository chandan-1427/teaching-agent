# ----------------------------------------------------------------------------
# Open Router Configuration
# ----------------------------------------------------------------------------
# Used for LLM API calls
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ----------------------------------------------------------------------------
# Agent Configuration
# ----------------------------------------------------------------------------
# Debug settings
DEBUG_MODE=true
DEBUG_LEVEL=2

# Type: "postgres" for PostgreSQL or "memory" for in-memory storage
STORAGE_TYPE=memory
#DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ----------------------------------------------------------------------------
# Scheduler Configuration
# ----------------------------------------------------------------------------
# Type: "redis" for distributed scheduling or "memory" for single-process
SCHEDULER_TYPE=memory
#REDIS_URL=redis://default:password@host:6379


# ----------------------------------------------------------------------------
# Sentry Configuration
# ----------------------------------------------------------------------------
# Enable error tracking and performance monitoring
SENTRY_ENABLED=true
SENTRY_DSN=https://<your-sentry-dsn>@<your-sentry-org>.ingest.de.sentry.io/<your-sentry-project-id>

# ----------------------------------------------------------------------------
# Open Telemetry Configuration
# ----------------------------------------------------------------------------
# Telemetry disabled
#TELEMETRY_ENABLED=false


# ----------------------------------------------------------------------------
# Hydra Configuration
# ----------------------------------------------------------------------------
# Enable authentication
AUTH__ENABLED=true
AUTH__PROVIDER=hydra
HYDRA__ADMIN_URL=https://hydra-admin.getbindu.com
HYDRA__PUBLIC_URL=https://hydra.getbindu.com


# ----------------------------------------------------------------------------
# Vault Configuration
# ----------------------------------------------------------------------------
# Enable Vault integration for persistent credential storage
VAULT__ENABLED=false

# Vault server URL
VAULT__URL=https://vault.getbindu.com

# Vault authentication token
VAULT__TOKEN=your_vault_token_here
